# -------------------------------------------------------
# Environment variables — copy to .env and fill in values
# Never commit .env to version control
# -------------------------------------------------------

# KitchenOwl connection (required)
KITCHENOWL_API_URL=http://back:5000
KITCHENOWL_API_TOKEN=your-long-lived-token-here

# KitchenOwl household (defaults shown)
KITCHENOWL_HOUSEHOLD_ID=1
KITCHENOWL_DEFAULT_LIST_ID=1

# Server port (default: 8000)
MCP_PORT=8000

# OAuth — required for Gemini Enterprise Cloud Run deployment (defaults: disabled)
# REQUIRE_OAUTH=true
# OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# OAUTH_CLIENT_SECRET=GOCSPX-your-secret
# OAUTH_BASE_URL=https://kitchenowl-mcp-gemini-xxxx.run.app
