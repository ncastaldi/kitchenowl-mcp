# -------------------------------------------------------
# Environment variables — copy to .env and fill in values
# Never commit .env to version control
# -------------------------------------------------------

# KitchenOwl connection (required)
# Use the nginx frontend container, not the backend directly — the backend
# speaks uwsgi binary protocol, not HTTP. Adjust the hostname to match your
# docker-compose service/container name for the KitchenOwl web container.
KITCHENOWL_API_URL=http://kitchenowl-front:80
KITCHENOWL_API_TOKEN=your-long-lived-token-here

# KitchenOwl household (defaults shown)
KITCHENOWL_HOUSEHOLD_ID=1
KITCHENOWL_DEFAULT_LIST_ID=1

# Server port (default: 8000)
MCP_PORT=8000
