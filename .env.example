# -------------------------------------------------------
# Environment variables — copy to .env and fill in values
# Never commit .env to version control
# -------------------------------------------------------

# App
APP_NAME={project-name}
APP_ENV=development          # development | staging | production
DEBUG=true

# API / Auth
SECRET_KEY=change-me-in-production   # generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/{project-name}

# CORS (comma-separated origins for development)
CORS_ORIGINS=http://localhost:5173

# Add project-specific keys below this line
# -------------------------------------------------------
